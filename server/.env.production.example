# SpeakPro 生产环境配置模板
# 复制为 .env.production 并填入真实值

# ---- 数据库 ----
DB_HOST=postgres
DB_PORT=5432
DB_NAME=speakpro
DB_USER=speakpro
DB_PASSWORD=<STRONG_PASSWORD_HERE>

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- 服务端口 ----
NEST_PORT=3000
GO_PORT=8080

# ---- JWT ----
JWT_SECRET=<RANDOM_64_CHAR_SECRET>
JWT_EXPIRES_IN=2h

# ---- CORS（逗号分隔允许的域名）----
CORS_ORIGINS=https://admin.speakpro.com,https://speakpro.com

# ---- 讯飞 AI ----
XUNFEI_APP_ID=<YOUR_APP_ID>
XUNFEI_API_KEY=<YOUR_API_KEY>
XUNFEI_API_SECRET=<YOUR_API_SECRET>

# ---- 通义千问 ----
QWEN_API_KEY=<YOUR_QWEN_KEY>

# ---- 阿里云 OSS ----
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=speakpro
OSS_ACCESS_KEY_ID=<YOUR_ACCESS_KEY>
OSS_ACCESS_KEY_SECRET=<YOUR_SECRET_KEY>
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# ---- 生产域名 ----
APP_DOMAIN=speakpro.com
API_BASE_URL=https://api.speakpro.com
