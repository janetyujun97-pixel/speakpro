# === 数据库 ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=speakpro
DB_USER=speakpro
DB_PASSWORD=speakpro_dev_123

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# === JWT ===
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# === 服务端口 ===
NEST_PORT=3000
GO_PORT=8080

# === 讯飞开放平台 ===
XUNFEI_APP_ID=
XUNFEI_API_KEY=
XUNFEI_API_SECRET=

# === 通义千问 ===
QWEN_API_KEY=
QWEN_MODEL=qwen-max

# === 阿里云 OSS ===
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=speakpro
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# === Web URL（邮件 reset 链接拼接用） ===
WEB_URL=http://localhost:3001

# === SMS / OTP ===
# log: dev 模式，验证码打到 NestJS 日志
# aliyun: 走阿里云短信（需填凭证）
SMS_PROVIDER=log
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=SpeakPro
ALIYUN_SMS_TEMPLATE_CODE=

# === Apple Sign-In ===
# bundle id 或 Service ID（和 identityToken 的 aud 一致）
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# === WeChat 开放平台 ===
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# === 邮件（教师端密码重置） ===
# log: dev 默认，链接打到日志
# smtp: 走 SMTP（填下面凭证）
MAIL_PROVIDER=log
MAIL_HOST=
MAIL_PORT=465
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@speakpro.local

# === 环境 ===
NODE_ENV=development
